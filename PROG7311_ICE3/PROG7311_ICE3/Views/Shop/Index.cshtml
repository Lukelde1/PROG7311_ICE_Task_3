@model IEnumerable<PROG7311_ICE3.Models.Product>
@{
    ViewData["Title"] = "Products";
}

<style>
    .page-heading {
        font-family: 'Syne', sans-serif;
        font-size: 2.8rem;
        font-weight: 800;
        margin-bottom: 0.4rem;
        letter-spacing: -1px;
    }

    .page-sub {
        color: #888;
        margin-bottom: 2.5rem;
        font-size: 0.95rem;
    }

    .product-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1.2rem;
    }

    .product-card {
        background: #1a1a1a;
        border: 1px solid #2a2a2a;
        border-radius: 12px;
        padding: 1.8rem;
        transition: border-color 0.2s, transform 0.2s;
    }

        .product-card:hover {
            border-color: #e8ff4d;
            transform: translateY(-3px);
        }

    .product-name {
        font-family: 'Syne', sans-serif;
        font-size: 1.25rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
    }

    .product-price {
        color: #e8ff4d;
        font-size: 1.4rem;
        font-weight: 500;
        margin-bottom: 1.4rem;
    }

    .btn {
        display: inline-block;
        padding: 0.65rem 1.4rem;
        background: #e8ff4d;
        color: #0f0f0f;
        border: none;
        border-radius: 8px;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.9rem;
        font-weight: 700;
        cursor: pointer;
        transition: opacity 0.2s;
        width: 100%;
    }

        .btn:hover {
            opacity: 0.85;
        }
</style>

<h1 class="page-heading">Our Products</h1>
<p class="page-sub">All prices in South African Rand</p>

<div class="product-grid">
    @foreach (var product in Model)
    {
        <div class="product-card">
            <div class="product-name">@product.Name</div>
            <div class="product-price">R @product.Price.ToString("N2")</div>
            <form asp-action="AddToCart" asp-controller="Shop" method="post">
                <input type="hidden" name="productId" value="@product.Id" />
                <button type="submit" class="btn">Add to Cart</button>
            </form>
        </div>
    }
</div>